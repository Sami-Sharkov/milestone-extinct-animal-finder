<Window x:Class="SpeciesDetector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SpeciesDetector"
        Title="Species Detector — Motion Monitor" Height="696" Width="1160"
        Background="#1E1E2E" Foreground="#CDD6F4"
        WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="1"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <local:LogLineColorConverter x:Key="LogLineColorConverter"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#313244"/>
        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#313244"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#45475A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseBtn" TargetType="Button" BasedOn="{StaticResource TitleBarBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F38BA8"/>
                                <Setter Property="Foreground" Value="#11111B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E78284"/>
                                <Setter Property="Foreground" Value="#11111B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="DetectionCard" TargetType="Border">
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMatch}" Value="True">
                    <Setter Property="BorderBrush" Value="#A6E3A1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatChip" TargetType="Border">
            <Setter Property="Background" Value="#11111B"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <!-- Sleek Custom ScrollBar Style globally in the window -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="false"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="false"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#313244" CornerRadius="4" Margin="1" x:Name="ThumbBorder"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#45475A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="true">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#CBA6F7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent" SnapsToDevicePixels="true">
                                    <Track x:Name="PART_Track" IsDirectionReversed="false" IsEnabled="{TemplateBinding IsEnabled}">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="false"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="false"/>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#313244" CornerRadius="4" Margin="1" x:Name="ThumbBorder"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="true">
                                                                <Setter TargetName="ThumbBorder" Property="Background" Value="#45475A"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="true">
                                                                <Setter TargetName="ThumbBorder" Property="Background" Value="#CBA6F7"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title Bar -->
            <RowDefinition Height="*"/>    <!-- Content Body -->
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#11111B" BorderBrush="#313244" BorderThickness="0,0,0,1" Height="36">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Title & Icon -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="🦎" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Species Detector — Motion Monitor" FontSize="12" FontWeight="Bold" Foreground="#CDD6F4" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Control Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinBtn" Content="─" Style="{StaticResource TitleBarBtn}" Click="MinBtn_Click"/>
                    <Button x:Name="MaxBtn" Content="▢" Style="{StaticResource TitleBarBtn}" Click="MaxBtn_Click"/>
                    <Button x:Name="CloseBtn" Content="✕" Style="{StaticResource TitleBarCloseBtn}" Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Body Content -->
        <Grid Grid.Row="1" Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#181825" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🦎" FontSize="22" Margin="0,0,8,0"/>
                    <TextBlock Text="Not Actually Extinct — Species Detector" FontSize="20" FontWeight="Bold"
                               Foreground="#CBA6F7" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="TargetSpeciesText" Text="Target: loading..." FontSize="12"
                           Foreground="#F9E2AF" Margin="0,6,0,2" FontStyle="Italic"/>
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="ServerStatusDot" Width="8" Height="8" Fill="#6C7086" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ServerStatusText" Text="Detection server: starting..." FontSize="11"
                               Foreground="#6C7086" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="StatusText" Text="Connecting..." FontSize="13"
                           Foreground="#A6E3A1" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Log list + detection history -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="310"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#181825" BorderBrush="#45475A" BorderThickness="1" CornerRadius="8">
                <ListBox x:Name="LogList" Background="Transparent" BorderThickness="0" Padding="6"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="NoWrap"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{Binding Converter={StaticResource LogLineColorConverter}}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Title & Navigation Bar -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Detections" FontWeight="Bold" FontSize="13"
                               Foreground="#CBA6F7" VerticalAlignment="Center"/>
                    
                    <!-- Navigation Panel -->
                    <StackPanel x:Name="NavigationPanel" Grid.Column="1" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                        <Button x:Name="GoToLatestBtn" Content="↷ Latest" Style="{StaticResource GhostButton}"
                                Height="24" Padding="6,0" Margin="0,0,8,0" FontSize="10" FontWeight="Bold"
                                Click="GoToLatestBtn_Click"/>
                        <Button x:Name="PrevDetectionBtn" Content="◀" Style="{StaticResource GhostButton}"
                                Width="26" Height="24" Padding="0" Margin="0,0,4,0" FontSize="10"
                                Click="PrevDetectionBtn_Click"/>
                        <TextBlock x:Name="DetectionCounterText" Text="0 / 0" Foreground="#CDD6F4" FontSize="11"
                                   VerticalAlignment="Center" Margin="4,0,4,0" FontWeight="Bold"/>
                        <Button x:Name="NextDetectionBtn" Content="▶" Style="{StaticResource GhostButton}"
                                Width="26" Height="24" Padding="0" Margin="4,0,0,0" FontSize="10"
                                Click="NextDetectionBtn_Click"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <TextBlock x:Name="NoDetectionsText"
                               Text="No detections yet — waiting for motion or Auto Poll."
                               TextWrapping="Wrap" Foreground="#6C7086" FontSize="12"
                               FontStyle="Italic" Margin="0,4,0,0"/>
                    
                    <!-- Single Active Detection Container -->
                    <ScrollViewer x:Name="DetectionViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <Border x:Name="ActiveDetectionCard" Style="{StaticResource DetectionCard}">
                            <StackPanel>
                                <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                       Height="220" HorizontalAlignment="Stretch"/>
                                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap"
                                           Foreground="#CDD6F4" FontSize="11" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#181825" CornerRadius="8" Padding="10,8" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight">
                <Button x:Name="TestLocalImageBtn" Style="{StaticResource AccentButton}"
                        Content="📁 Test Local Image"
                        Background="#A6E3A1" Foreground="#11111B"
                        Margin="0,0,10,0"
                        Click="TestLocalImageBtn_Click"/>
                <Button x:Name="TestSnapshotBtn" Style="{StaticResource AccentButton}"
                        Content="📷 Test Snapshot"
                        Background="#89B4FA" Foreground="#11111B"
                        Margin="0,0,10,0"
                        Click="TestSnapshotBtn_Click"/>
                <CheckBox x:Name="AutoPollCheckbox"
                          Content="Auto Poll (10 s)" Foreground="#CDD6F4"
                          VerticalAlignment="Center" Margin="0,0,14,0"
                          Checked="AutoPollCheckbox_CheckedChanged"
                          Unchecked="AutoPollCheckbox_CheckedChanged"/>
                <Separator Width="1" Background="#45475A" Margin="0,2,14,2"/>
                <Button x:Name="OpenSnapshotsBtn" Style="{StaticResource GhostButton}"
                        Content="🗂 Open Snapshots"
                        Margin="0,0,10,0"
                        Click="OpenSnapshotsBtn_Click"/>
                <Button x:Name="ClearLogBtn" Style="{StaticResource GhostButton}"
                        Content="🧹 Clear Log"
                        Margin="0,0,14,0"
                        Click="ClearLogBtn_Click"/>
                <Separator Width="1" Background="#45475A" Margin="0,2,14,2"/>
                <Border Style="{StaticResource StatChip}">
                    <TextBlock x:Name="CountText" Text="Events: 0" FontSize="11" Foreground="#6C7086"/>
                </Border>
                <Border Style="{StaticResource StatChip}">
                    <TextBlock x:Name="AnimalCountText" Text="Animals: 0" FontSize="11" Foreground="#89B4FA"/>
                </Border>
                <Border Style="{StaticResource StatChip}" Margin="0">
                    <TextBlock x:Name="TargetCountText" Text="Targets: 0" FontSize="11" FontWeight="Bold" Foreground="#F38BA8"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Grid>
</Window>
