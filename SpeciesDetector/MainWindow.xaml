<Window x:Class="SpeciesDetector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Species Detector — Motion Monitor" Height="660" Width="1160"
        Background="#1E1E2E" Foreground="#CDD6F4">

    <Window.Resources>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DetectionCard" TargetType="Border">
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMatch}" Value="True">
                    <Setter Property="BorderBrush" Value="#A6E3A1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#181825" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🦎" FontSize="22" Margin="0,0,8,0"/>
                    <TextBlock Text="Not Actually Extinct — Species Detector" FontSize="20" FontWeight="Bold"
                               Foreground="#CBA6F7" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="TargetSpeciesText" Text="Target: loading..." FontSize="12"
                           Foreground="#F9E2AF" Margin="0,6,0,2" FontStyle="Italic"/>
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="ServerStatusDot" Width="8" Height="8" Fill="#6C7086" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ServerStatusText" Text="Detection server: starting..." FontSize="11"
                               Foreground="#6C7086" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="StatusText" Text="Connecting..." FontSize="13"
                           Foreground="#A6E3A1" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Log list + detection history -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="310"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#181825" BorderBrush="#45475A" BorderThickness="1" CornerRadius="8">
                <ListBox x:Name="LogList" Background="Transparent" BorderThickness="0"
                         Foreground="#CDD6F4" FontFamily="Consolas" FontSize="12" Padding="6"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Border>

            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Detections" FontWeight="Bold" FontSize="13"
                           Foreground="#CBA6F7" Margin="0,0,0,6"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DetectionHistoryList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource DetectionCard}">
                                    <StackPanel>
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                               Height="120" HorizontalAlignment="Stretch"/>
                                        <TextBlock Text="{Binding Summary}" TextWrapping="Wrap"
                                                   Foreground="#CDD6F4" FontSize="11" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#181825" CornerRadius="8" Padding="10,8" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight">
                <Button x:Name="TestLocalImageBtn" Style="{StaticResource AccentButton}"
                        Content="📁 Test Local Image"
                        Background="#A6E3A1" Foreground="#11111B"
                        Margin="0,0,10,0"
                        Click="TestLocalImageBtn_Click"/>
                <Button x:Name="TestSnapshotBtn" Style="{StaticResource AccentButton}"
                        Content="📷 Test Snapshot"
                        Background="#89B4FA" Foreground="#11111B"
                        Margin="0,0,10,0"
                        Click="TestSnapshotBtn_Click"/>
                <CheckBox x:Name="AutoPollCheckbox"
                          Content="Auto Poll (10 s)" Foreground="#CDD6F4"
                          VerticalAlignment="Center" Margin="0,0,14,0"
                          Checked="AutoPollCheckbox_CheckedChanged"
                          Unchecked="AutoPollCheckbox_CheckedChanged"/>
                <Separator Width="1" Background="#45475A" Margin="0,2,14,2"/>
                <TextBlock x:Name="CountText"
                           Text="Events: 0" FontSize="11"
                           Foreground="#6C7086" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="AnimalCountText"
                           Text="Animals: 0" FontSize="11"
                           Foreground="#89B4FA" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="TargetCountText"
                           Text="Targets: 0" FontSize="11" FontWeight="Bold"
                           Foreground="#F38BA8" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
