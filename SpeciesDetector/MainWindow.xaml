<Window x:Class="SpeciesDetector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Species Detector — Motion Monitor" Height="500" Width="750"
        Background="#1E1E2E" Foreground="#CDD6F4">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="🦎 Species Detector" FontSize="20" FontWeight="Bold"
                       Foreground="#CBA6F7" Margin="0,0,0,4"/>
            <TextBlock Text="Target: Rhodonessa caryophyllacea (Pink-headed Duck)" FontSize="12"
                       Foreground="#F9E2AF" Margin="0,0,0,4" FontStyle="Italic"/>
            <TextBlock x:Name="StatusText" Text="Connecting..." FontSize="13"
                       Foreground="#A6E3A1"/>
        </StackPanel>

        <!-- Log list -->
        <ListBox x:Name="LogList" Grid.Row="1"
                 Background="#181825" BorderBrush="#45475A" BorderThickness="1"
                 Foreground="#CDD6F4" FontFamily="Consolas" FontSize="12"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
            <Button x:Name="TestSnapshotBtn" Content="📷 Test Snapshot" Background="#89B4FA" Foreground="#11111B" FontWeight="Bold" Padding="10,2" Margin="0,0,15,0" Click="TestSnapshotBtn_Click"/>
            <CheckBox x:Name="AutoPollCheckbox" Content="Auto Poll (10s)" Foreground="#CDD6F4" VerticalAlignment="Center" Margin="0,0,15,0" Checked="AutoPollCheckbox_CheckedChanged" Unchecked="AutoPollCheckbox_CheckedChanged"/>
            <TextBlock x:Name="CountText" Text="Events received: 0" FontSize="11" Foreground="#6C7086" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <TextBlock x:Name="AnimalCountText" Text="Animals detected: 0" FontSize="11" Foreground="#89B4FA" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <TextBlock x:Name="TargetCountText" Text="Targets matched: 0" FontSize="11" Foreground="#F38BA8" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
